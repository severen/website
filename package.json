    "eslint-plugin-svelte3": "^4.0.0",
    "postcss": "^8.4.21",
    "postcss-load-config": "^4.0.1",
    "prettier": "^2.8.3",
    "prettier-plugin-tailwindcss": "^0.2.1",
    "svelte": "^3.55.1",
    "svelte-check": "^3.0.2",
